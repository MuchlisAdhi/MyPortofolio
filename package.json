{
  "name": "muchlis-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "eslint",
    "zip:out": "powershell -NoProfile -Command \"if (!(Test-Path 'out')) { throw 'Folder out tidak ditemukan. Jalankan npm run build terlebih dahulu.' }; if (Test-Path 'deploy-public_html.zip') { Remove-Item 'deploy-public_html.zip' -Force }; tar -a -c -f deploy-public_html.zip -C out .\"",
    "build:deploy": "npm run build && npm run zip:out"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "i18next": "^26.0.3",
    "next": "16.1.6",
    "next-i18next": "^16.0.5",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "19.3.0-canary-f93b9fd4-20251217",
    "react-dom": "19.3.0-canary-f93b9fd4-20251217",
    "react-i18next": "^17.0.2",
    "react-icons": "^5.5.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "react": "19.3.0-canary-f93b9fd4-20251217",
    "react-dom": "19.3.0-canary-f93b9fd4-20251217"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "next-sitemap": "^4.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
