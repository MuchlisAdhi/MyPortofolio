Options -MultiViews
DirectoryIndex index.html

<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect www host to the canonical non-www host.
  RewriteCond %{HTTP_HOST} ^www\.muchlisadhi\.my\.id$ [NC]
  RewriteRule ^(.*)$ https://muchlisadhi.my.id/$1 [R=301,L]

  # Serve file/folder as-is when it exists.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback SPA route (only for URL without extension).
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{1,5}$
  RewriteRule ^ index.html [L]
</IfModule>
