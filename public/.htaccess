Options -MultiViews
DirectoryIndex index.html

<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  <FilesMatch "opengraph-image$">
    ForceType image/png
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
  <Files "sitemap.xml">
    Header set Content-Type "application/xml; charset=UTF-8"
  </Files>
</IfModule>

<IfModule mod_brotli.c>
  <Files "sitemap.xml">
    SetEnv no-brotli 1
  </Files>
</IfModule>

<IfModule mod_deflate.c>
  <Files "sitemap.xml">
    SetEnv no-gzip 1
  </Files>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonicalize protocol and host: force HTTPS + non-www.
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.muchlisadhi\.my\.id$ [NC]
  RewriteRule ^(.*)$ https://muchlisadhi.my.id/$1 [R=301,L]

  # Normalize accidental trailing slash on static files (e.g. /sitemap.xml/).
  RewriteCond %{REQUEST_URI} ^/(.+\.[a-zA-Z0-9]{1,8})/$
  RewriteRule ^ %1 [R=301,L]

  # If a matching .html file exists, serve it before directory autoindex.
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # Serve file/folder as-is when it exists.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback SPA route (only for URL without extension).
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{1,5}$
  RewriteRule ^ index.html [L]
</IfModule>
